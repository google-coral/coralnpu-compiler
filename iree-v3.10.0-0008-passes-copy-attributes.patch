From 3629f5b846d4c7bfb23937343385c030783e9077 Mon Sep 17 00:00:00 2001
From: Shaked Flur <sflur@google.com>
Date: Fri, 3 Jul 2026 22:07:48 +0200
Subject: [PATCH] [passes] copy attributes

This is needed to preserve affinity annotations.
---
 .../iree/compiler/Dialect/Flow/IR/FlowOps.cpp |  1 +
 .../Dialect/Flow/Transforms/RegionOpUtils.cpp |  1 +
 .../PropagateLinalgTranspose.cpp              |  5 +-
 .../QuantizedConvToConv.cpp                   | 87 ++++++++++++-------
 .../QuantizedMatmulToMatmul.cpp               | 20 ++++-
 5 files changed, 76 insertions(+), 38 deletions(-)

diff --git a/compiler/src/iree/compiler/Dialect/Flow/IR/FlowOps.cpp b/compiler/src/iree/compiler/Dialect/Flow/IR/FlowOps.cpp
index 6fdf177d0f..1ae5360162 100644
--- a/compiler/src/iree/compiler/Dialect/Flow/IR/FlowOps.cpp
+++ b/compiler/src/iree/compiler/Dialect/Flow/IR/FlowOps.cpp
@@ -597,6 +597,7 @@ bool dropUnusedAndRedundantDispatchRegionResults(
   auto newRegionOp =
       Flow::DispatchRegionOp::create(rewriter, regionOp.getLoc(), resultTypes,
                                      dynamicDims, regionOp.getWorkload());
+  newRegionOp->setDialectAttrs(regionOp->getDialectAttrs());
   newRegionOp.getBody().takeBody(regionOp.getBody());
 
   // Update terminator.
diff --git a/compiler/src/iree/compiler/Dialect/Flow/Transforms/RegionOpUtils.cpp b/compiler/src/iree/compiler/Dialect/Flow/Transforms/RegionOpUtils.cpp

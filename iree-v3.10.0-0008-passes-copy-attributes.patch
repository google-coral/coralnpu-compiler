   auto newRegionOp = IREE::Flow::DispatchRegionOp::create(
       rewriter, regionOp->getLoc(), resultTypes, regionDynamicDims,
       regionOp.getWorkload());
+  newRegionOp->setDialectAttrs(regionOp->getDialectAttrs());
   rewriter.inlineRegionBefore(regionOp.getBody(), newRegionOp.getBody(),
                               newRegionOp.getBody().begin());
   rewriter.replaceOp(
diff --git a/compiler/src/iree/compiler/GlobalOptimization/PropagateLinalgTranspose.cpp b/compiler/src/iree/compiler/GlobalOptimization/PropagateLinalgTranspose.cpp
index 60ba3f5b85..962d40516b 100644
--- a/compiler/src/iree/compiler/GlobalOptimization/PropagateLinalgTranspose.cpp
+++ b/compiler/src/iree/compiler/GlobalOptimization/PropagateLinalgTranspose.cpp
@@ -138,8 +138,11 @@ static void specializeGenericTransposeOp(RewriterBase &rewriter,
   for (AffineExpr expr : outMap.getResults()) {
     perm.push_back(*inMap.getResultPosition(expr));
   }
-  rewriter.replaceOpWithNewOp<linalg::TransposeOp>(
+  auto transposeOp = rewriter.replaceOpWithNewOp<linalg::TransposeOp>(
       genericOp, genericOp.getDpsInputs()[0], genericOp.getDpsInits()[0], perm);
+  if (auto attr = genericOp->getAttr("stream.affinity")) {
+    transposeOp->setAttr("stream.affinity", attr);
+  }
 }
 
 //===----------------------------------------------------------------------===//
diff --git a/compiler/src/iree/compiler/GlobalOptimization/QuantizedConvToConv.cpp b/compiler/src/iree/compiler/GlobalOptimization/QuantizedConvToConv.cpp
